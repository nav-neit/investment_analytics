# ── LLM backend ───────────────────────────────────────────────────────────────
# one of: anthropic | ollama | none
# "none" runs the whole app with extractive (non-LLM) summaries.
LLM_BACKEND=none

# hosted API (LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# local models via Ollama (LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
# fast summariser (news cards, digests)
OLLAMA_FAST_MODEL=llama3.2:3b
# deeper analysis model (chat, investment briefs) — e.g. a finance-tuned 8B
OLLAMA_DEEP_MODEL=llama3.2:3b

# ── cache TTLs in seconds (optional overrides) ────────────────────────────────
# TTL_QUOTES=600
# TTL_HISTORY=3600
# TTL_FUNDAMENTALS=21600
# TTL_NEWS=1800
# TTL_LLM=21600
